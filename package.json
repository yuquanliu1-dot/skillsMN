{
  "name": "skillsmn",
  "version": "0.1.0",
  "description": "Local skill management desktop application for Claude Code",
  "main": "dist/src/main/index.js",
  "author": "skillsMN Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "concurrently -k \"cross-env BROWSER=none npm run dev:renderer\" \"npm run dev:main\" \"cross-env NODE_ENV=development electron .\"",
    "dev:main": "tsc --watch",
    "dev:renderer": "vite",
    "build": "tsc && npm run build:renderer",
    "build:watch": "tsc --watch",
    "build:renderer": "vite build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=lcov --coverageReporters=html",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "cross-env DEBUG=true playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:p0": "playwright test --grep \"@P0\"",
    "test:e2e:p1": "playwright test --grep \"@P1\"",
    "test:e2e:p2": "playwright test --grep \"@P2\"",
    "test:e2e:smoke": "playwright test tests/e2e/specs/00-setup.spec.ts tests/e2e/specs/01-navigation.spec.ts",
    "test:e2e:skills": "playwright test tests/e2e/specs/02-skills.spec.ts tests/e2e/specs/03-editor.spec.ts",
    "test:e2e:discover": "playwright test tests/e2e/specs/04-discover.spec.ts",
    "test:e2e:private": "playwright test tests/e2e/specs/05-private-repos.spec.ts",
    "test:e2e:ai": "playwright test tests/e2e/specs/06-ai-creation.spec.ts",
    "test:e2e:settings": "playwright test tests/e2e/specs/07-settings.spec.ts",
    "test:e2e:errors": "playwright test tests/e2e/specs/08-error-handling.spec.ts",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.{ts,tsx,css,json}'",
    "clean": "rimraf dist/",
    "rebuild": "npm run clean && npm run build",
    "package": "electron-builder",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.74",
    "@anthropic-ai/sdk": "^0.78.0",
    "@monaco-editor/react": "^4.6.0",
    "@parcel/watcher": "^2.5.6",
    "chokidar": "^3.6.0",
    "electron": "^28.0.0",
    "electron-store": "^8.0.0",
    "gray-matter": "^4.0.3",
    "monaco-editor": "^0.55.1",
    "node-fetch": "^2.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-window": "^1.8.11",
    "trash": "^6.1.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.33",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
